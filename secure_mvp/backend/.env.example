DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=api.example.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.example.com,https://api.example.com
DJANGO_CORS_ALLOWED_ORIGINS=https://app.example.com
DATABASE_URL=postgresql://app_user:change_me@localhost:5432/secure_mvp
DJANGO_ADMIN_URL=internal-admin/
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1
SESSION_COOKIE_DOMAIN=
CSRF_COOKIE_DOMAIN=
LOG_LEVEL=INFO
